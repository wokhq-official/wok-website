<script>
const { createApp, ref, watch, onMounted, onUnmounted } = Vue;
const { createVuetify } = Vuetify;

const vuetify = createVuetify({
  theme: {
    defaultTheme: "light",
    themes: {
      light: {
        colors: {
          primary: "#1976D2",
          secondary: "#424242",
        },
      },
    },
  },
});

const app = createApp({
  setup() {
    const name = ref("World");
    const loading = ref(false);
    const result = ref("");
    const drawer = ref(null);
    const dialog = ref(false);

    // --- Waitlist state ---
    const waitlistEmail = ref("");
    const waitlistLoading = ref(false);
    const waitlistError = ref("");
    const waitlistSuccess = ref(false);

    const questions = ref([
      {
        title: "What makes WOK different?",
        text: "WOK focuses on skills, transparency, and explainable decisions — not resumes or keywords.",
      },
      {
        title: "Does AI make hiring decisions?",
        text: "WOK focuses on skills and potential rather than just resumes, providing a more holistic view of candidates.",
      },
      {
        title: "Is WOK only for full-time jobs?",
        text: "WOK focuses on skills and potential rather than just resumes, providing a more holistic view of candidates.",
      },
      {
        title: "How are skills validated?",
        text: "WOK focuses on skills and potential rather than just resumes, providing a more holistic view of candidates.",
      },
      {
        title: "Is my data secure?",
        text: "WOK focuses on skills and potential rather than just resumes, providing a more holistic view of candidates.",
      },
    ]);

    function scrollTo(id) {
      const el = document.getElementById(id);
      if (el) {
        el.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }

    // Reset waitlist state when dialog closes
    watch(dialog, (val) => {
      if (!val) {
        waitlistEmail.value = "";
        waitlistError.value = "";
        waitlistSuccess.value = false;
      }
    });

    async function fetchData() {
      loading.value = true;
      result.value = "";
      try {
        const response = await fetch(
          "https://jsonplaceholder.typicode.com/todos/1",
        );
        const data = await response.json();
        result.value = `Fetched: "${data.title}"`;
      } catch (error) {
        result.value = "Error: " + error.message;
      } finally {
        loading.value = false;
      }
    }

    // --- Waitlist submission ---
    async function submitWaitlist() {
      waitlistError.value = "";

      if (!waitlistEmail.value || !waitlistEmail.value.includes("@")) {
        waitlistError.value = "Please enter a valid email address.";
        return;
      }

      waitlistLoading.value = true;

      try {
        const response = await fetch("https://your-api.com/waitlist", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email: waitlistEmail.value }),
        });

        if (!response.ok)
          throw new Error(`Server error: ${response.status}`);

        waitlistSuccess.value = true;
        setTimeout(() => {
          dialog.value = false;
        }, 2000);
      } catch (error) {
        waitlistError.value = "Something went wrong. Please try again.";
      } finally {
        waitlistLoading.value = false;
      }
    }

    // --- Hero image slideshow ---
    let slideshowInterval = null;

    function initSlideshow() {
      const slides = document.querySelectorAll(".hero_img-slideshow .hero_img");
      if (!slides.length) return;

      let current = 0;
      slides[current].classList.add("active");

      slideshowInterval = setInterval(() => {
        slides[current].classList.remove("active");
        current = (current + 1) % slides.length;
        slides[current].classList.add("active");
      }, 4000);
    }

    // --- Tooltip pop-in on scroll ---
    let tooltipObserver = null;

    function initTooltipAnimations() {
      const wrapper = document.querySelector(".hero_img-wrapper");
      if (!wrapper) return;

      const tooltips = [
        wrapper.querySelector("[data-pop-order='1']"),
        wrapper.querySelector("[data-pop-order='2']"),
        wrapper.querySelector("[data-pop-order='3']"),
        wrapper.querySelector("[data-pop-order='4']"),
      ].filter(Boolean);

      tooltipObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              tooltips.forEach((el, index) => {
                setTimeout(() => {
                  el.classList.add("pop-in");
                }, index * 300);
              });
              tooltipObserver.disconnect();
            }
          });
        },
        { threshold: 0.3 }
      );

      tooltipObserver.observe(wrapper);
    }

    onMounted(() => {
      initSlideshow();
      initTooltipAnimations();
    });

    onUnmounted(() => {
      if (slideshowInterval) clearInterval(slideshowInterval);
      if (tooltipObserver) tooltipObserver.disconnect();
    });

    return {
      name,
      loading,
      result,
      drawer,
      dialog,
      questions,
      scrollTo,
      fetchData,
      // Waitlist
      waitlistEmail,
      waitlistLoading,
      waitlistError,
      waitlistSuccess,
      submitWaitlist,
    };
  },
});

app.use(vuetify);
app.mount("#app");
</script>